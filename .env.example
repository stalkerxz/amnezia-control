DJANGO_SETTINGS_MODULE=amnezia_control.settings.prod
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost
DJANGO_FORCE_SSL=0
APP_PORT=8090
POSTGRES_DB=amnezia
POSTGRES_USER=amnezia
POSTGRES_PASSWORD=amnezia
POSTGRES_HOST=db
POSTGRES_PORT=5432
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
LIMITS_ENFORCE_EVERY_MINUTES=5
CONFIG_ENCRYPTION_KEY=GENERATE_WITH_python_-c_"from_cryptography.fernet_import_Fernet;print(Fernet.generate_key().decode())"
TIME_ZONE=UTC
SSH_ALLOW_UNKNOWN_HOSTS=0
MEDIA_ROOT=/data/media
NOTIFICATIONS_ENABLED=1
NOTIFICATIONS_CHANNELS=email
NOTIFICATIONS_EMAIL_FROM=no-reply@example.com
NOTIFICATIONS_BASE_URL=http://127.0.0.1:8090
NOTIFICATIONS_EXPIRING_DAYS=3
NOTIFICATIONS_TELEGRAM_BOT_TOKEN=
NOTIFICATIONS_TELEGRAM_ADMIN_CHAT_IDS=
